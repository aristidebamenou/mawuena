    <ul class="flex flex-wrap justify-center gap-6 text-[11px] uppercase tracking-[0.2em]">
      <li><a href="#soins" class="hover:opacity-70">Les soins</a></li>
      <li><a href="#maison" class="hover:opacity-70">La maison</a></li>
      <li><a href="#contact" class="hover:opacity-70">Contact</a></li>
      <li><a href="#" class="hover:opacity-70">Mentions légales</a></li>
    </ul>

    <p class="text-[11px] uppercase tracking-[0.2em] opacity-60">© 2026 Maison Mawuena</p>
