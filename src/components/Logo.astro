---
/* Logo primaire (recréé en SVG inline d'après la charte : capsule + symbole). */
const { width = 34, height = 52 } = Astro.props;
---

<svg width={width} height={height} viewBox="0 0 60 92" fill="none" aria-hidden="true" class="shrink-0">
  <rect x="2" y="2" width="56" height="88" rx="28" stroke="currentColor" stroke-width="3"></rect>
  <circle cx="30" cy="24" r="4" fill="currentColor"></circle>
  <path
    d="M12 44 C18 34, 42 34, 48 44 C46 56, 40 60, 38 58 L38 52 L22 52 L22 58 C20 60, 14 56, 12 44 Z"
    stroke="currentColor"
    stroke-width="3"
    fill="none"
    stroke-linejoin="round"></path>
</svg>