---
import Logo from './Logo.astro';
import { NAV } from '../data/site.js';
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-colors duration-300">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8" aria-label="Navigation principale">
    <a href="#hero" class="flex items-center gap-3" aria-label="Maison Mawuena — retour en haut de page">
      <Logo />
    </a>

    <!-- Nav desktop -->
    <ul class="hidden items-center gap-8 text-xs uppercase tracking-[0.2em] md:flex">
      {NAV.map((item) => (
        <li><a href={item.href} class="hover:opacity-70 transition-opacity">{item.label}</a></li>
      ))}
      <li>
        <a
          href="#contact"
          class="inline-block border border-current px-5 py-2.5 transition-colors hover:bg-olive hover:text-wall hover:border-olive"
        >
          Réserver
        </a>
      </li>
    </ul>

    <!-- Burger mobile -->
    <button id="menu-toggle" class="md:hidden p-2" aria-expanded="false" aria-controls="mobile-menu" aria-label="Ouvrir le menu">
      <svg width="26" height="18" viewBox="0 0 26 18" fill="none" aria-hidden="true">
        <path d="M1 1h24M1 9h24M1 17h24" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
    </button>
  </nav>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="hidden md:hidden bg-olive text-wall">
    <ul class="flex flex-col gap-1 px-6 py-6 text-sm uppercase tracking-[0.25em]">
      {NAV.map((item, i) => (
        <li>
          <a href={item.href} class:list={['block py-3', i < NAV.length - 1 && 'border-b border-grass/40']}>
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-4">
        <a href="#contact" class="block border border-wall px-5 py-3 text-center">Réserver une séance</a>
      </li>
    </ul>
  </div>
</header>

<script>
  /* ---------- Header : fond olive au scroll ---------- */
  const header = document.getElementById('site-header');
  const onScroll = () => {
    const scrolled = window.scrollY > 40;
    header.classList.toggle('bg-olive', scrolled);
    header.classList.toggle('text-wall', true); // le hero est sombre : texte clair dès le départ
    header.classList.toggle('shadow-lg', scrolled);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  /* ---------- Menu mobile ---------- */
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle.addEventListener('click', () => {
    const open = mobileMenu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
  });
  // Ferme le menu après clic sur un lien (ancres internes)
  mobileMenu.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    })
  );
</script>