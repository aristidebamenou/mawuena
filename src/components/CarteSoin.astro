---
import { Image } from 'astro:assets';

const { soin } = Astro.props;
---

<article class="reveal group">
  <div class="overflow-hidden rounded-xl">
    <Image
      src={soin.image}
      alt={soin.alt}
      class="aspect-[4/5] w-full object-cover transition-transform duration-700 group-hover:scale-105"
      widths={[400, 800]}
      sizes="(min-width: 768px) 33vw, 100vw"
      loading="lazy"
    />
  </div>
  <h3 class="font-display mt-6 text-xl italic">{soin.titre}</h3>
  <p class="mt-3 text-sm leading-relaxed text-linen">{soin.description}</p>
  <p class="mt-4 text-[11px] uppercase tracking-[0.25em] text-linen/80">{soin.tarif}</p>
</article>